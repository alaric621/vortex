{
  "name": "vortex",
  "displayName": "vortex",
  "description": "",
  "version": "0.0.1",
  "publisher": "alaric",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:vht",
    "onView:vortex-explorer",
    "onFileSystem:vortex-fs",
    "onCommand:vortex.request.refresh",
    "onCommand:vortex.request.create",
    "onCommand:vortex.request.rename",
    "onCommand:vortex.request.delete",
    "onCommand:vortex.request.send",
    "onCommand:vortex.request.stop"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Vortex",
      "properties": {
        "vortex.output.strictLogFormat": {
          "type": "boolean",
          "default": true,
          "description": "Use strict output format consistent with log.md templates."
        }
      }
    },
    "resourceLabelFormatters": [
      {
        "scheme": "vortex-fs",
        "formatting": {
          "label": "${path}",
          "tildify": true,
          "separator": "/"
        }
      }
    ],
    "commands": [
      {
        "command": "vortex.request.refresh",
        "title": "Vortex: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "vortex.request.create",
        "title": "Vortex: Create",
        "icon": "$(add)"
      },
      {
        "command": "vortex.request.rename",
        "title": "Vortex: Update",
        "icon": "$(edit)"
      },
      {
        "command": "vortex.request.delete",
        "title": "Vortex: Delete",
        "icon": "$(trash)"
      },
      {
        "command": "vortex.request.send",
        "title": "Vortex: Send Request",
        "icon": "$(play)"
      },
      {
        "command": "vortex.request.stop",
        "title": "Vortex: Stop Request",
        "icon": "$(debug-stop)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vortex.request.create",
          "when": "view == vortex-explorer",
          "group": "navigation@1"
        },
        {
          "command": "vortex.request.refresh",
          "when": "view == vortex-explorer",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "vortex.request.create",
          "when": "view == vortex-explorer",
          "group": "inline@0"
        },
        {
          "command": "vortex.request.send",
          "when": "view == vortex-explorer && viewItem == vortex.requestNode.idle",
          "group": "inline@1"
        },
        {
          "command": "vortex.request.stop",
          "when": "view == vortex-explorer && viewItem == vortex.requestNode.running",
          "group": "inline@1"
        }
      ],
      "editor/title": [
        {
          "command": "vortex.request.send",
          "when": "resourceExtname == .vht && !vortex.client.busy",
          "group": "navigation@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vortex",
          "title": "vortex",
          "icon": "$(insert)"
        }
      ]
    },
    "views": {
      "vortex": [
        {
          "id": "vortex-explorer",
          "icon": "$(insert)",
          "name": "Vortex Requests"
        }
      ]
    },
    "languages": [
      {
        "id": "vht",
        "aliases": [
          "Vortex HTTP"
        ],
        "extensions": [
          ".vht"
        ],
        "configuration": "./syntaxes/vht.language-configuration.json"
      },
      {
        "id": "vortex-log",
        "aliases": [
          "Vortex Log"
        ]
      }
    ],
    "grammars": [
      {
        "language": "vht",
        "scopeName": "source.vht",
        "path": "./syntaxes/vht.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.inline.javascript": "javascript",
          "hook.block.javascript": "javascript"
        }
      },
      {
        "language": "vortex-log",
        "scopeName": "source.vortex-log",
        "path": "./syntaxes/vortex-log.tmLanguage.json"
      }
    ],
    "keybindings": [
      {
        "command": "vortex.request.create",
        "key": "c",
        "mac": "c",
        "when": "focusedView == vortex-explorer && !inputFocus"
      },
      {
        "command": "vortex.request.delete",
        "key": "d",
        "mac": "backspace",
        "when": "focusedView == vortex-explorer && listFocus  && !inputFocus && listHasSelectionOrFocus"
      },
      {
        "command": "vortex.request.rename",
        "key": "a",
        "mac": "a",
        "when": "focusedView == vortex-explorer && listFocus  && !inputFocus && listHasSelectionOrFocus"
      },
      {
        "command": "vortex.request.send",
        "key": "enter",
        "mac": "enter",
        "when": "focusedView == vortex-explorer && listFocus && !inputFocus && viewItem == vortex.requestNode.idle"
      },
      {
        "command": "vortex.request.stop",
        "key": "enter",
        "mac": "enter",
        "when": "focusedView == vortex-explorer && listFocus && !inputFocus && viewItem == vortex.requestNode.running"
      },
      {
        "command": "vortex.request.refresh",
        "key": "r",
        "mac": "r",
        "when": "focusedView == vortex-explorer && listFocus && !inputFocus"
      },
      {
        "command": "vortex.request.send",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && resourceExtname == .vht && vim.mode == 'Normal'"
      },
      {
        "command": "vortex.request.stop",
        "key": "shift+escape",
        "mac": "shift+escape",
        "when": "editorTextFocus && resourceExtname == .vht && vortex.client.busy"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p tsconfig.app.json",
    "watch": "tsc -watch",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=json-summary --coverage.thresholds.lines=65 --coverage.thresholds.functions=60 --coverage.thresholds.statements=65 --coverage.thresholds.branches=50"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vitest/coverage-v8": "^4.0.18",
    "msw": "^2.12.11",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
