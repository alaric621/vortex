{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsbuild/vitest",
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts",
    "package.json",
    "syntaxes/**/*.json"
  ],
  "exclude": ["node_modules", "dist", "temp"]
}
