{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vortex Transaction Log",
  "scopeName": "source.vortex-log",
  "patterns": [
    {
      "include": "#separators"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#json-body"
    },
    {
      "include": "#html-body"
    },
    {
      "include": "#key-value"
    },
    {
      "include": "#header-item"
    }
  ],
  "repository": {
    "separators": {
      "patterns": [
        {
          "match": "^=+\\s+HTTP TRANSACTION START\\s+=+$",
          "name": "markup.heading.vortexlog"
        },
        {
          "match": "^=+\\s+HTTP TRANSACTION END\\s+=+$",
          "name": "markup.heading.vortexlog"
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "^\\[(REQUEST|RESPONSE|BEFORE|AFTER)\\]$",
          "captures": {
            "1": {
              "name": "keyword.control.vortexlog"
            }
          }
        },
        {
          "match": "^-{5,}\\s+HOOK\\s+(PRE|POST)\\s+-{5,}$",
          "captures": {
            "1": {
              "name": "keyword.control.vortexlog"
            }
          }
        },
        {
          "match": "^\\[(\\d{2}:\\d{2}:\\d{2}\\.\\d{3})\\]",
          "captures": {
            "1": {
              "name": "constant.numeric.timestamp.vortexlog"
            }
          }
        }
      ]
    },
    "key-value": {
      "patterns": [
        {
          "match": "^(TIMESTAMP|REQUEST_ID|TRACE_ID|NODE|METHOD|URL|STATUS|TIME|TIMINGS|HEADERS|PAYLOAD|BODY):",
          "captures": {
            "1": {
              "name": "entity.name.tag.vortexlog"
            }
          }
        },
        {
          "match": "\\b(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|CONNECT|TRACE|SUBSCRIBE|UNSUBSCRIBE|WEBSOCKET|SSE|EVENTSOURCE)\\b",
          "name": "keyword.control.http.vortexlog"
        },
        {
          "match": "\\b\\d{3}\\b",
          "name": "constant.numeric.status-code.vortexlog"
        },
        {
          "match": "(https?|wss?)://[^\\s]+",
          "name": "string.unquoted.url.vortexlog"
        },
        {
          "match": "\\bFAILED\\b",
          "name": "invalid.deprecated.vortexlog"
        },
        {
          "match": "^status:\\s+",
          "name": "entity.name.tag.vortexlog"
        },
        {
          "match": "^duration:\\s+",
          "name": "entity.name.tag.vortexlog"
        },
        {
          "match": "^content-type:\\s+",
          "name": "entity.name.tag.vortexlog"
        },
        {
          "match": "^(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|CONNECT|TRACE|SUBSCRIBE|UNSUBSCRIBE|WEBSOCKET|SSE|EVENTSOURCE)\\s+((https?|wss?)://[^\\s]+)\\s+HTTP\\/\\d(?:\\.\\d+)?$",
          "captures": {
            "1": {
              "name": "keyword.control.http.vortexlog"
            },
            "2": {
              "name": "string.unquoted.url.vortexlog"
            }
          }
        }
      ]
    },
    "json-body": {
      "patterns": [
        {
          "begin": "^\\s*(\\{|\\[(?!\\d{2}:\\d{2}:\\d{2}\\.\\d{3}\\]))\\s*$",
          "end": "(?=^\\[\\d{2}:\\d{2}:\\d{2}\\.\\d{3}\\]|^=+\\s+HTTP TRANSACTION END\\s+=+$|^status:|^duration:|^content-type:|^timings:|^(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|CONNECT|TRACE|SUBSCRIBE|UNSUBSCRIBE|WEBSOCKET|SSE|EVENTSOURCE)\\s+((https?|wss?)://[^\\s]+)\\s+HTTP\\/\\d(?:\\.\\d+)?$)",
          "contentName": "source.json",
          "patterns": [
            {
              "include": "source.json"
            }
          ]
        }
      ]
    },
    "html-body": {
      "patterns": [
        {
          "begin": "^\\s*<(?:!doctype\\s+html|html\\b|head\\b|body\\b|[a-zA-Z][\\w:-]*)",
          "end": "(?=^\\[\\d{2}:\\d{2}:\\d{2}\\.\\d{3}\\]|^=+\\s+HTTP TRANSACTION END\\s+=+$|^status:|^duration:|^content-type:|^timings:|^(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|CONNECT|TRACE|SUBSCRIBE|UNSUBSCRIBE|WEBSOCKET|SSE|EVENTSOURCE)\\s+((https?|wss?)://[^\\s]+)\\s+HTTP\\/\\d(?:\\.\\d+)?$)",
          "contentName": "text.html.basic",
          "patterns": [
            {
              "include": "text.html.basic"
            }
          ]
        }
      ]
    },
    "header-item": {
      "patterns": [
        {
          "match": "^(\\s*-\\s*)([^:]+)(:)(.*)$",
          "captures": {
            "2": {
              "name": "constant.other.header.key.vortexlog"
            },
            "3": {
              "name": "punctuation.separator.key-value.vortexlog"
            },
            "4": {
              "name": "string.unquoted.header.value.vortexlog"
            }
          }
        }
      ]
    }
  }
}
